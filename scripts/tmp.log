\[ 3000 + 0.02 \times 6x - 0.02 \times 110,000 = 8000 \]
\[ 3000 + 1.2x - 2200 = 8000 \]
\[ 1.2x + 800 = 8000 \]
\[ 1.2x = 7200 \]
\[ x = \frac{7200}{1.2} \]
